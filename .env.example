# ── NVIDIA NIM API key ──────────────────────────────────────
# Get one free at https://build.nvidia.com/
# NV-Agent accepts any of these (checked in order):
NVIDIA_NIM_API_KEY="nvapi-xxxxxxx"
# NVIDIA_API_KEY="nvapi-xxxxxxx"
# NGC_API_KEY="xxxxxxx"

# ── Optional: Protect your instance with an API key ─────────
# When set, all /api/* endpoints require X-API-Key header or ?api_key= param
# When not set, the API is open (suitable for local development)
NV_AGENT_AUTH_KEY="your-secret-auth-key"

# ── Optional: Rate limiting ─────────────────────────────────
# Format: "N/unit" — e.g., "60/minute", "10/second", "100/hour"
# Default: "60/minute" (60 requests per minute per IP)
NV_AGENT_RATE_LIMIT="60/minute"

# ── Optional: Vector store backend ──────────────────────────
# Default: "faiss" (in-memory FAISS with local persistence)
# Options: "faiss", "chromadb", "qdrant"
# NV_AGENT_VECTOR_STORE="faiss"

# ── ChromaDB options (when NV_AGENT_VECTOR_STORE=chromadb) ──
# NV_AGENT_CHROMADB_COLLECTION="nv_agent_kb"
# NV_AGENT_CHROMADB_PERSIST_DIR="/path/to/chromadb"

# ── Qdrant options (when NV_AGENT_VECTOR_STORE=qdrant) ──────
# Local file-based mode (default):
# NV_AGENT_QDRANT_PATH="/path/to/qdrant"
# Remote server mode:
# NV_AGENT_QDRANT_HOST="localhost"
# NV_AGENT_QDRANT_PORT="6333"
# NV_AGENT_QDRANT_API_KEY="your-api-key"  # if using auth
# NV_AGENT_QDRANT_COLLECTION="nv_agent_kb"