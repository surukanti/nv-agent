# ── NV-Agent Production Environment ─────────────────────────────────
# Copy this file to .env.prod and fill in your values
# DO NOT commit .env.prod — add it to .gitignore

# ════════════════════════════════════════════════════════════════════
# REQUIRED: NVIDIA NIM API Key
# Get yours at: https://build.nvidia.com/
# Supports: NVIDIA_NIM_API_KEY, NVIDIA_API_KEY, NGC_API_KEY
# ════════════════════════════════════════════════════════════════════
NVIDIA_NIM_API_KEY=nvapi-your-api-key-here

# ════════════════════════════════════════════════════════════════════
# OPTIONAL: Model overrides (defaults in config.py)
# ════════════════════════════════════════════════════════════════════
# MODEL=meta/llama-3.1-70b-instruct
# EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# ════════════════════════════════════════════════════════════════════
# SERVER SETTINGS
# ════════════════════════════════════════════════════════════════════
NV_HOST=0.0.0.0
NV_PORT=8000

# ════════════════════════════════════════════════════════════════════
# AUTHENTICATION (set to enable API key protection on /api/*)
# Generate a strong random key: openssl rand -hex 32
# ════════════════════════════════════════════════════════════════════
NV_AGENT_AUTH_KEY=your-secure-random-api-key-here

# ════════════════════════════════════════════════════════════════════
# RATE LIMITING (format: N/unit, e.g., "60/minute", "10/second")
# Per-IP sliding window
# ═════════════════════════════════════════════════════════════════════
NV_AGENT_RATE_LIMIT=60/minute

# ════════════════════════════════════════════════════════════════════
# VECTOR STORE BACKEND
# Options: faiss (default), qdrant, chromadb
# ════════════════════════════════════════════════════════════════════
NV_AGENT_VECTOR_STORE=faiss

# ════════════════════════════════════════════════════════════════════
# QDRANT SETTINGS (only used if NV_AGENT_VECTOR_STORE=qdrant)
# Service name in docker-compose.prod.yml: "qdrant"
# ════════════════════════════════════════════════════════════════════
NV_AGENT_QDRANT_HOST=qdrant
NV_AGENT_QDRANT_PORT=6333

# ════════════════════════════════════════════════════════════════════
# CHROMADB SETTINGS (only used if NV_AGENT_VECTOR_STORE=chromadb)
# ════════════════════════════════════════════════════════════════════
NV_AGENT_CHROMADB_PERSIST_DIR=/app/kb/index/chromadb

# ════════════════════════════════════════════════════════════════════
# CORS ORIGINS (comma-separated, no trailing slash)
# For production, restrict to your actual domain
# ════════════════════════════════════════════════════════════════════
# NV_CORS_ORIGINS=https://yourdomain.com

# ════════════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO